# Limitless API Configuration
LIMITLESS_API_KEY=your_limitless_api_key_here
LIMITLESS_API_URL=https://api.limitless.ai

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Database Configuration
DATABASE_URL=mysql://user:password@localhost:3306/limitless

# Cron Job Configuration
FETCH_INTERVAL_CRON=*/5 * * * *  # Fetch lifelogs every 5 minutes
PROCESS_INTERVAL_CRON=*/2 * * * *  # Process lifelogs every 2 minutes
FETCH_DAYS=1  # Number of days to fetch lifelogs for
PROCESSING_BATCH_SIZE=5  # Number of lifelogs to process in each batch