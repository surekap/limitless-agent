# ── Limitless Agent ──────────────────────────────────────────────────────────
LIMITLESS_API_KEY=your_limitless_api_key_here
LIMITLESS_API_URL=https://api.limitless.ai
LIMITLESS_TIMEZONE=UTC

# ── Claude (Anthropic) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ─────────────────────────────────────────────────────────────────
# Single Postgres database shared by all agents (each agent uses its own schema)
DATABASE_URL=postgres://user:password@localhost/secondbrain

# ── Notion ───────────────────────────────────────────────────────────────────
NOTION_TOKEN=secret_...

# ── Todoist ──────────────────────────────────────────────────────────────────
TODOIST_API_TOKEN=your_todoist_token_here

# ── Stock Analysis (Perplexity) ──────────────────────────────────────────────
PERPLEXITY_API_KEY=pplx-...

# ── Fetch / Cron tuning ──────────────────────────────────────────────────────
FETCH_DAYS=10
FETCH_WINDOW_DAYS=30
# FETCH_START_DATE=2024-01-01
# FETCH_END_DATE=2024-12-31

# ── Archive tuning ───────────────────────────────────────────────────────────
ARCHIVE_AUDIO_SOURCES=auto,pendant
ARCHIVE_AUDIO_TIMEOUT_MS=30000
ARCHIVE_AUDIO_RETRIES=1
ARCHIVE_AUDIO_RETRY_DELAY_MS=750
ARCHIVE_AUDIO_PROGRESS_EVERY=25
# ARCHIVE_START_DATE=2024-01-01
# ARCHIVE_END_DATE=2024-12-31
# ARCHIVE_SKIP_LIFELOGS=1
# ARCHIVE_SKIP_CHATS=1
# ARCHIVE_SKIP_AUDIO=1
